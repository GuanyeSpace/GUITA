generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceChannel {
  MINIAPP
  ADMIN
  API
  OPS
}

enum UserHostRelationType {
  FOLLOWING
  FAVORITED
  COMPLETED_INTRO
  PARTICIPANT
}

enum UserStatus {
  active
  inactive
  banned
  deleted
}

enum IdentityType {
  wechat_miniapp
  wecom_external
  phone
}

enum SessionStatus {
  active
  revoked
  expired
}

enum ReplayStatus {
  draft
  published
  archived
}

enum VideoSourceType {
  external
  cos
  vod
}

model Host {
  id            String             @id @default(cuid())
  slug          String             @unique
  displayName   String
  title         String
  tagline       String
  ageBand       String
  mobilityLevel String
  isPublished   Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  userRelations UserHostRelation[]
  events        Event[]
  replays       LiveReplay[]
}

model User {
  id               String               @id
  nickname         String?
  avatarUrl        String?
  phone            String?
  phoneCountryCode String               @default("+86")
  status           UserStatus           @default(active)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  hostRelations    UserHostRelation[]
  identities       Identity[]
  sessions         Session[]
  events           Event[]
  progresses       UserReplayProgress[]

  @@unique([phone, phoneCountryCode])
}

model UserHostRelation {
  id            String               @id @default(cuid())
  userId        String
  hostId        String
  relationType  UserHostRelationType @default(FOLLOWING)
  sourceChannel SourceChannel
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  host          Host                 @relation(fields: [hostId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hostId, relationType], map: "user_host_relation_unique")
  @@index([hostId])
  @@index([sourceChannel])
}

model Identity {
  id         String       @id @default(cuid())
  userId     String
  type       IdentityType
  externalId String
  unionId    String?
  metadata   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id])

  @@unique([type, externalId])
  @@index([userId])
}

model Session {
  id        String        @id @default(cuid())
  userId    String
  status    SessionStatus @default(active)
  userAgent String?
  ip        String?
  issuedAt  DateTime      @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  user      User          @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Event {
  id         String   @id @default(cuid())
  userId     String?
  name       String
  payload    Json
  hostId     String?
  channel    String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
  host       Host?    @relation(fields: [hostId], references: [id])

  @@index([userId, occurredAt])
  @@index([name, occurredAt])
}

model LiveReplay {
  id              String               @id @default(cuid())
  hostId          String
  title           String
  description     String?
  coverUrl        String?
  videoUrl        String
  videoSource     VideoSourceType      @default(external)
  durationSeconds Int
  liveAt          DateTime?
  publishedAt     DateTime?
  status          ReplayStatus         @default(draft)
  metadata        Json?
  createdBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  host            Host                 @relation(fields: [hostId], references: [id])
  progresses      UserReplayProgress[]

  @@index([hostId, status, publishedAt])
  @@index([status, publishedAt])
}

model UserReplayProgress {
  id              String     @id @default(cuid())
  userId          String
  replayId        String
  positionSeconds Int        @default(0)
  durationSeconds Int        @default(0)
  completed       Boolean    @default(false)
  firstViewedAt   DateTime   @default(now())
  lastViewedAt    DateTime   @default(now())
  completedAt     DateTime?
  user            User       @relation(fields: [userId], references: [id])
  replay          LiveReplay @relation(fields: [replayId], references: [id])

  @@unique([userId, replayId])
  @@index([userId, lastViewedAt])
  @@index([replayId])
}
