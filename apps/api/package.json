{
  "name": "@guita/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @guita/shared-schema build",
    "dev": "tsx watch src/main.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "prelint": "pnpm --filter @guita/shared-schema build",
    "lint": "eslint src --ext .ts",
    "pretest": "pnpm --filter @guita/shared-schema build",
    "test": "node --import tsx --test --test-concurrency=1 src/common/guita-id.spec.ts test/auth.e2e-spec.ts test/replays.e2e-spec.ts"
  },
  "dependencies": {
    "@guita/shared-schema": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/client": "^6.19.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jose": "^6.1.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4"
  }
}
