page {
  background: #fffaf5;
  color: #1f2937;
  font-family: 'PingFang SC', 'Hiragino Sans GB', sans-serif;
}

.container {
  padding: 48rpx 32rpx;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.08);
}

.page-title {
  font-size: 48rpx;
  font-weight: 600;
  line-height: 1.3;
}

.page-copy {
  margin-top: 20rpx;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.7;
}
